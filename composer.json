{
  "name": "chafficui/elevenelo",
  "description": "PHP client for the 11elo Soccer ELO API",
  "type": "library",
  "license": "MIT",
  "keywords": ["soccer", "football", "elo", "bundesliga", "api", "client"],
  "homepage": "https://11elo.com",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "ElevenElo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ElevenElo\\Tests\\": "tests/"
    }
  },
  "support": {
    "issues": "https://github.com/Chafficui/11elo-sdk/issues",
    "source": "https://github.com/Chafficui/11elo-sdk/tree/main/php"
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true
  }
}
